        public static AddressesRow? Get(int AddressID)
        {
            AddressesRow? oAddress = null;
            SqlDataReader? reader = null;

            if (IsCachingEnabled)
            {
                oAddress = Cache.Get<AddressesRow>(AddressID);

                if (null != oAddress)
                    return oAddress;
            }

            try
            {
                string strStoredProc = "GetAddressSp";

                SqlParams sqlParams = new SqlParams();
                sqlParams.Add(DataAccess.Params.ID("@AddressID", AddressID));

                reader = DataAccess.ReaderFromProc(strStoredProc, sqlParams);

                if (reader.HasRows && reader.Read())
                {
                    oAddress = new AddressesRow();

                    oAddress.AddressID = DataAccess.GetID(reader, "AddressID");
                    oAddress.PatientID = DataAccess.GetID(reader, "PatientID");
                    oAddress.Name = DataAccess.GetStringOrNull(reader, "Name");
                    oAddress.Line1 = DataAccess.GetStringOrNull(reader, "Line1");
                    oAddress.Line2 = DataAccess.GetStringOrNull(reader, "Line2");
                    oAddress.City = DataAccess.GetStringOrNull(reader, "City");
                    oAddress.State = DataAccess.GetStringOrNull(reader, "State");
                    oAddress.Zip = DataAccess.GetZipOrNull(reader, "Zip");
                    oAddress.Country = DataAccess.GetStringOrNull(reader, "Country");
                    oAddress.DateCreated = DataAccess.GetDateTime(reader, "DateCreated");
                    oAddress.LastUpdated = DataAccess.GetDateTime(reader, "LastUpdated");
                    oAddress.Data = DataAccess.GetStringOrNull(reader, "Data");

                }
                else
                {
                    //todo  handle error
                }
            }
            finally
            {
                DBUtilities.CloseReader(reader);
            }

            if (IsCachingEnabled && null != oAddress)
            {

                Cache.Insert(oAddress, oAddress.AddressID, oAddress.AddressID.ToString());

            }

            return oAddress;
        }

