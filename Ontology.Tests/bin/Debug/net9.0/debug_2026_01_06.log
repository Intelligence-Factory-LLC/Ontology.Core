        public static AddressesDataTable GetAddressesByPatientID(int PatientID)
        {
            AddressesDataTable tblAddresses = new AddressesDataTable();
            SqlDataReader? reader = null;

            try
            {
                string strStoredProc = "GetAddressesByPatientIDSp";

                SqlParams sqlParams = new SqlParams();

                sqlParams.Add(DataAccess.Params.ID("@PatientID", PatientID));


                reader = DataAccess.ReaderFromProc(strStoredProc, sqlParams);

                while (reader.HasRows && reader.Read())
                {
                    AddressesRow rowAddress = new AddressesRow();

                    rowAddress.AddressID = DataAccess.GetID(reader, "AddressID");
                    rowAddress.PatientID = DataAccess.GetID(reader, "PatientID");
                    rowAddress.Name = DataAccess.GetStringOrNull(reader, "Name");
                    rowAddress.Line1 = DataAccess.GetStringOrNull(reader, "Line1");
                    rowAddress.Line2 = DataAccess.GetStringOrNull(reader, "Line2");
                    rowAddress.City = DataAccess.GetStringOrNull(reader, "City");
                    rowAddress.State = DataAccess.GetStringOrNull(reader, "State");
                    rowAddress.Zip = DataAccess.GetZipOrNull(reader, "Zip");
                    rowAddress.Country = DataAccess.GetStringOrNull(reader, "Country");
                    rowAddress.DateCreated = DataAccess.GetDateTime(reader, "DateCreated");
                    rowAddress.LastUpdated = DataAccess.GetDateTime(reader, "LastUpdated");
                    rowAddress.Data = DataAccess.GetStringOrNull(reader, "Data");

                    tblAddresses.Add(rowAddress);
                }
            }
            finally
